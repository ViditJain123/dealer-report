# Supabase — database only (no Auth, Storage, Realtime, or Edge Functions).
# All access is server-side, so these are NOT NEXT_PUBLIC_ and must never be committed.
# Find both values in the Supabase dashboard → Project Settings → API Keys.

# Project URL, e.g. https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_URL=

# Secret key — the `service_role` JWT or the newer `sb_secret_...` key.
# It bypasses Row Level Security. Never use the publishable/anon key here.
SUPABASE_SERVICE_ROLE_KEY=
